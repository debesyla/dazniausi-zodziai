    {
      "contractId": "dadurkevicius-dml6-vs-jcl-comparison",
      "productType": "chunked-comparison",
      "publication": {
        "status": "published",
        "scope": "Every row from the reviewed DML6 and JCL comparison files.",
        "access": "Static JSON chunks with separate views for coverage, lemma occurrences, and missing types."
      },
      "views": [
        {
          "id": "jcl-types-dml6-coverage",
          "sourceRole": "types-coverage",
          "title": "JCL types and DML6 coverage",
          "description": "A raw JCL token count paired with a categorical DML6 coverage code. The code is not a frequency.",
          "ordering": { "field": "jclTokenCount", "direction": "descending" },
          "chunkBytes": 262144,
          "fields": [
            { "id": "word", "label": "Word form", "type": "string", "sourceColumn": 0 },
            { "id": "jclTokenCount", "label": "JCL token count", "type": "raw-token-count", "unit": "tokens", "sourceColumn": 1 },
            {
              "id": "dml6CoverageCode",
              "label": "DML6 coverage",
              "type": "coverage-code",
              "unit": "category",
              "sourceColumn": 2,
              "values": {
                "0": "not in DML6",
                "1": "main entry",
                "2": "geographic name",
                "3": "abbreviation"
              }
            }
          ]
        },
        {
          "id": "dml6-lemmas-jcl-occurrences",
          "sourceRole": "lemma-occurrences",
          "title": "DML6 lemmas and JCL occurrences",
          "description": "JCL occurrences for a DML6 lemma and source part-of-speech code.",
          "ordering": { "field": "jclLemmaOccurrenceCount", "direction": "descending" },
          "chunkBytes": 262144,
          "fields": [
            { "id": "lemma", "label": "Lemma", "type": "string", "sourceColumn": 0 },
            { "id": "partOfSpeechCode", "label": "Source part-of-speech code", "type": "source-pos-code", "sourceColumn": 1 },
            { "id": "jclLemmaOccurrenceCount", "label": "JCL occurrence count", "type": "raw-token-count", "unit": "tokens", "sourceColumn": 2 }
          ]
        },
        {
          "id": "jcl-types-missing-in-dml6",
          "sourceRole": "missing-types",
          "title": "JCL types missing from DML6",
          "description": "The source's filtered list of types not found in DML6, with their raw JCL token counts.",
          "ordering": { "field": "jclTokenCount", "direction": "descending" },
          "chunkBytes": 262144,
          "fields": [
            { "id": "word", "label": "Word form", "type": "string", "sourceColumn": 0 },
            { "id": "jclTokenCount", "label": "JCL token count", "type": "raw-token-count", "unit": "tokens", "sourceColumn": 1 }
          ]
        }
      ]
