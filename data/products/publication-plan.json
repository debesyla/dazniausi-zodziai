    {
      "contractId": "dadurkevicius-dml6-vs-jcl-comparison",
      "productType": "chunked-comparison",
      "publication": {
        "status": "published",
        "scope": "Every row from the reviewed DML6 and JCL comparison files.",
        "access": "Static JSON chunks with separate views for coverage, lemma occurrences, and missing types."
      },
      "views": [
        {
          "id": "jcl-types-dml6-coverage",
          "sourceRole": "types-coverage",
          "title": "JCL types and DML6 coverage",
          "description": "A raw JCL token count paired with a categorical DML6 coverage code. The code is not a frequency.",
          "ordering": { "field": "jclTokenCount", "direction": "descending" },
          "chunkBytes": 262144,
          "fields": [
            { "id": "word", "label": "Word form", "type": "string", "sourceColumn": 0 },
            { "id": "jclTokenCount", "label": "JCL token count", "type": "raw-token-count", "unit": "tokens", "sourceColumn": 1 },
            {
              "id": "dml6CoverageCode",
              "label": "DML6 coverage",
              "type": "coverage-code",
              "unit": "category",
              "sourceColumn": 2,
              "values": {
                "0": "not in DML6",
                "1": "main entry",
                "2": "geographic name",
                "3": "abbreviation"
              }
            }
          ]
        },
        {
          "id": "dml6-lemmas-jcl-occurrences",
          "sourceRole": "lemma-occurrences",
          "title": "DML6 lemmas and JCL occurrences",
          "description": "JCL occurrences for a DML6 lemma and source part-of-speech code.",
          "ordering": { "field": "jclLemmaOccurrenceCount", "direction": "descending" },
          "chunkBytes": 262144,
          "fields": [
            { "id": "lemma", "label": "Lemma", "type": "string", "sourceColumn": 0 },
            { "id": "partOfSpeechCode", "label": "Source part-of-speech code", "type": "source-pos-code", "sourceColumn": 1 },
            { "id": "jclLemmaOccurrenceCount", "label": "JCL occurrence count", "type": "raw-token-count", "unit": "tokens", "sourceColumn": 2 }
          ]
        },
        {
          "id": "jcl-types-missing-in-dml6",
          "sourceRole": "missing-types",
          "title": "JCL types missing from DML6",
          "description": "The source's filtered list of types not found in DML6, with their raw JCL token counts.",
          "ordering": { "field": "jclTokenCount", "direction": "descending" },
          "chunkBytes": 262144,
          "fields": [
            { "id": "word", "label": "Word form", "type": "string", "sourceColumn": 0 },
            { "id": "jclTokenCount", "label": "JCL token count", "type": "raw-token-count", "unit": "tokens", "sourceColumn": 1 }
          ]
        }
      ],
      "analysisProfiles": [
        {
          "id": "dml6-jcl-coverage-by-frequency-band",
          "type": "frequency-band-coverage",
          "sourceRole": "types-coverage",
          "title": "DML6 coverage by JCL frequency band",
          "description": "Counts of JCL word forms and their raw token mass in transparent frequency bands, split by labelled DML6 coverage category.",
          "summaryMaxBytes": 32768,
          "frequencyBands": [
            { "id": "one", "label": "1", "minimum": 1, "maximum": 1 },
            { "id": "two-to-four", "label": "2–4", "minimum": 2, "maximum": 4 },
            { "id": "five-to-nine", "label": "5–9", "minimum": 5, "maximum": 9 },
            { "id": "ten-to-ninety-nine", "label": "10–99", "minimum": 10, "maximum": 99 },
            { "id": "one-hundred-to-nine-hundred-ninety-nine", "label": "100–999", "minimum": 100, "maximum": 999 },
            { "id": "one-thousand-plus", "label": "1,000+", "minimum": 1000, "maximum": null }
          ],
          "drilldown": {
            "limit": 50,
            "maxBytes": 16384,
            "ordering": { "field": "jclTokenCount", "direction": "descending", "tieBreak": "word-ascending" }
          }
        }
      ]
    },
    {
      "contractId": "utka-ccll2-war-ukraine-comparison",
      "productType": "chunked-comparison",
      "publication": {
        "status": "published",
        "scope": "Every row from the reviewed CCLL2, wartime media, and social-network comparison file.",
        "access": "Static JSON chunks. A null metric means the word is absent from that source, not that its count is zero."
      },
      "views": [
        {
          "id": "ccll2-war-ukraine-normalized-metrics",
          "sourceRole": "normalized-comparison",
          "title": "CCLL2, wartime media, and social-network metrics",
          "description": "Token and document counts normalized by the source to 100 million source words. Metrics remain separate and nullable.",
          "ordering": { "field": "word", "direction": "ascending" },
          "chunkBytes": 262144,
          "fields": [
            { "id": "word", "label": "Word form", "type": "string", "sourceColumn": 0 },
            { "id": "ccll2TokenCount", "label": "CCLL2 normalized token count", "type": "normalized-token-count", "unit": "tokens per 100 million source words", "sourceColumn": 1, "nullable": true, "normalization": { "sourceTokens": 162000000, "targetTokens": 100000000 } },
            { "id": "ccll2DocumentCount", "label": "CCLL2 normalized document count", "type": "normalized-document-count", "unit": "documents per 100 million source words", "sourceColumn": 2, "nullable": true, "normalization": { "sourceTokens": 162000000, "targetTokens": 100000000 } },
            { "id": "mediaTokenCount", "label": "Wartime media normalized token count", "type": "normalized-token-count", "unit": "tokens per 100 million source words", "sourceColumn": 3, "nullable": true, "normalization": { "sourceTokens": 36000000, "targetTokens": 100000000 } },
            { "id": "mediaDocumentCount", "label": "Wartime media normalized document count", "type": "normalized-document-count", "unit": "documents per 100 million source words", "sourceColumn": 4, "nullable": true, "normalization": { "sourceTokens": 36000000, "targetTokens": 100000000 } },
            { "id": "socialTokenCount", "label": "Wartime social-network normalized token count", "type": "normalized-token-count", "unit": "tokens per 100 million source words", "sourceColumn": 5, "nullable": true, "normalization": { "sourceTokens": 2000000, "targetTokens": 100000000 } },
            { "id": "socialDocumentCount", "label": "Wartime social-network normalized document count", "type": "normalized-document-count", "unit": "documents per 100 million source words", "sourceColumn": 6, "nullable": true, "normalization": { "sourceTokens": 2000000, "targetTokens": 100000000 } }
          ]
        }
      ]
    },
